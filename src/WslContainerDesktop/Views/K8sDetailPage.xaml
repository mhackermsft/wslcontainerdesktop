<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WslContainerDesktop.Views.K8sDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WslContainerDesktop.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Margin="24,14,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Width="40"
                Height="40"
                Padding="0"
                VerticalAlignment="Center"
                AutomationProperties.Name="Back to Kubernetes"
                Click="Back_Click"
                ToolTipService.ToolTip="Back to Kubernetes">
                <FontIcon FontSize="15" Glyph="&#xE72B;" />
            </Button>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <Border
                    Width="42"
                    Height="42"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <FontIcon
                        FontSize="19"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Glyph="&#xE9F5;" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>

            <!--  Actions  -->
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Button
                    Command="{x:Bind ViewModel.ScaleCommand}"
                    ToolTipService.ToolTip="Scale"
                    Visibility="{x:Bind ViewModel.SupportsScale, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE740;" />
                        <TextBlock Text="Scale" />
                    </StackPanel>
                </Button>
                <Button
                    Command="{x:Bind ViewModel.RestartCommand}"
                    AutomationProperties.Name="Rolling restart"
                    ToolTipService.ToolTip="Rolling restart"
                    Visibility="{x:Bind ViewModel.SupportsScale, Converter={StaticResource BoolToVis}}">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.TriggerCronCommand}"
                    ToolTipService.ToolTip="Run now"
                    Visibility="{x:Bind ViewModel.SupportsCron, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE768;" />
                        <TextBlock Text="Run now" />
                    </StackPanel>
                </Button>
                <Button
                    Command="{x:Bind ViewModel.ToggleSuspendCommand}"
                    AutomationProperties.Name="Suspend or resume"
                    ToolTipService.ToolTip="Suspend / resume"
                    Visibility="{x:Bind ViewModel.SupportsCron, Converter={StaticResource BoolToVis}}">
                    <FontIcon FontSize="14" Glyph="&#xE769;" />
                </Button>
                <Button Command="{x:Bind ViewModel.RefreshAllCommand}" AutomationProperties.Name="Refresh" ToolTipService.ToolTip="Refresh">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
                <Button ToolTipService.ToolTip="Delete" AutomationProperties.Name="Delete" Command="{x:Bind ViewModel.DeleteCommand}">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                </Button>
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Height="1"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!--  Tabs  -->
        <SelectorBar
            x:Name="DetailTabs"
            Grid.Row="2"
            SelectionChanged="DetailTabs_SelectionChanged">
            <SelectorBarItem
                x:Name="TabSummary"
                IsSelected="True"
                Text="Summary">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE946;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabKube" Text="Kube">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE943;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabDescribe" Text="Describe">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE7C3;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabLogs" Text="Logs">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE9D9;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
        </SelectorBar>

        <!--  Tab content  -->
        <Grid Grid.Row="3">
            <!--  Summary  -->
            <Border
                x:Name="SummaryPanel"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6">
                <ScrollViewer Padding="20,16">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="4">
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="KIND" />
                            <TextBlock Text="{x:Bind ViewModel.DisplayKind, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="NAME" />
                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="SCOPE" />
                            <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Use the Kube tab to view and edit the full manifest, or Describe for a detailed status view." />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!--  Kube (editable YAML)  -->
            <Grid x:Name="KubePanel" Visibility="Collapsed" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Button
                        Command="{x:Bind ViewModel.ApplyKubeCommand}"
                        Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE898;" />
                            <TextBlock Text="Apply changes to cluster" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.RefreshAllCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                            <TextBlock Text="Reload" />
                        </StackPanel>
                    </Button>
                    <ProgressRing
                        Width="20"
                        Height="20"
                        IsActive="{x:Bind ViewModel.ApplyingKube, Mode=OneWay}" />
                </StackPanel>

                <Border
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <TextBox
                        AcceptsReturn="True"
                        BorderThickness="0"
                        FontFamily="Consolas"
                        FontSize="12"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        Text="{x:Bind ViewModel.Yaml, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TextWrapping="NoWrap" />
                </Border>
            </Grid>

            <!--  Describe  -->
            <Border
                x:Name="DescribePanel"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="Collapsed">
                <ScrollViewer Padding="16,12" HorizontalScrollBarVisibility="Auto">
                    <TextBlock
                        FontFamily="Consolas"
                        FontSize="12"
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind ViewModel.DescribeText, Mode=OneWay}" />
                </ScrollViewer>
            </Border>

            <!--  Logs  -->
            <Grid x:Name="LogsPanel" Visibility="Collapsed" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Button Grid.Row="0" Command="{x:Bind ViewModel.RefreshLogsCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="Refresh logs" />
                    </StackPanel>
                </Button>
                <Border
                    Grid.Row="1"
                    Background="#0B0B0B"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ScrollViewer Padding="14,10" HorizontalScrollBarVisibility="Auto">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="12"
                            Foreground="#E6E6E6"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind ViewModel.LogsText, Mode=OneWay}" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <ProgressBar
                VerticalAlignment="Top"
                IsIndeterminate="True"
                Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</Page>
