<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WslContainerDesktop.Views.ContainerDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WslContainerDesktop.Helpers"
    xmlns:models="using:WslContainerDesktop.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StateToBrushConverter x:Key="StateToBrush" />
        <converters:StateToStringConverter x:Key="StateToString" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:HexToBrushConverter x:Key="HexToBrush" />
    </Page.Resources>

    <Grid Margin="24,14,24,16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Breadcrumb / header  -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Grid.Column="0"
                Width="40"
                Height="40"
                Padding="0"
                VerticalAlignment="Center"
                Click="Back_Click"
                ToolTipService.ToolTip="Back to containers">
                <FontIcon FontSize="15" Glyph="&#xE72B;" />
            </Button>

            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="12">
                <Border
                    Width="42"
                    Height="42"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <FontIcon
                        FontSize="19"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Glyph="&#xE7F4;" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse
                            Width="12"
                            Height="12"
                            VerticalAlignment="Center"
                            Fill="{x:Bind ViewModel.Selected.State, Mode=OneWay, Converter={StaticResource StateToBrush}}" />
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.Selected.Name, Mode=OneWay}" />
                        <Border
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="10">
                            <TextBlock
                                FontSize="12"
                                Text="{x:Bind ViewModel.Selected.State, Mode=OneWay, Converter={StaticResource StateToString}}" />
                        </Border>
                        <Border
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Background="#1F7A3D"
                            CornerRadius="10"
                            ToolTipService.ToolTip="{x:Bind ViewModel.Selected.GpuTooltip, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.Selected.HasGpu, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <FontIcon FontSize="12" Foreground="White" Glyph="&#xE950;" />
                                <TextBlock FontSize="12" Foreground="White" Text="GPU" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock
                        FontSize="13"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind ViewModel.Selected.Image, Mode=OneWay}"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>

            <!--  Actions  -->
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Button
                    Command="{x:Bind ViewModel.StartCommand}"
                    CommandParameter="{x:Bind ViewModel.Selected, Mode=OneWay}"
                    Style="{ThemeResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Start"
                    Visibility="{x:Bind ViewModel.Selected.IsStopped, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <FontIcon FontSize="14" Glyph="&#xE768;" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.StopCommand}"
                    CommandParameter="{x:Bind ViewModel.Selected, Mode=OneWay}"
                    ToolTipService.ToolTip="Stop"
                    Visibility="{x:Bind ViewModel.Selected.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <FontIcon FontSize="14" Glyph="&#xE71A;" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.RestartCommand}"
                    CommandParameter="{x:Bind ViewModel.Selected, Mode=OneWay}"
                    ToolTipService.ToolTip="Restart"
                    Visibility="{x:Bind ViewModel.Selected.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.KillCommand}"
                    CommandParameter="{x:Bind ViewModel.Selected, Mode=OneWay}"
                    ToolTipService.ToolTip="Kill (force stop)"
                    Visibility="{x:Bind ViewModel.Selected.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <FontIcon FontSize="14" Glyph="&#xE8BB;" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.TerminalCommand}"
                    CommandParameter="{x:Bind ViewModel.Selected, Mode=OneWay}"
                    ToolTipService.ToolTip="Open terminal"
                    Visibility="{x:Bind ViewModel.Selected.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <FontIcon FontSize="14" Glyph="&#xE756;" />
                </Button>
                <Button
                    Command="{x:Bind ViewModel.OpenPortCommand}"
                    CommandParameter="{x:Bind ViewModel.Selected, Mode=OneWay}"
                    ToolTipService.ToolTip="Open published port in browser">
                    <FontIcon FontSize="14" Glyph="&#xE774;" />
                </Button>
                <Button ToolTipService.ToolTip="Remove" Click="Remove_Click">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                </Button>
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Height="1"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!--  Tabs  -->
        <SelectorBar
            x:Name="DetailTabs"
            Grid.Row="2"
            SelectionChanged="DetailTabs_SelectionChanged">
            <SelectorBarItem
                x:Name="TabLogs"
                IsSelected="True"
                Text="Logs">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE9D9;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabSummary" Text="Summary">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE946;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabStats" Text="Stats">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE9D9;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabInspect" Text="Inspect">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE943;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabFiles" Text="Files">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE838;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
            <SelectorBarItem x:Name="TabChanges" Text="Changes">
                <SelectorBarItem.Icon>
                    <FontIcon Glyph="&#xE1CB;" />
                </SelectorBarItem.Icon>
            </SelectorBarItem>
        </SelectorBar>

        <!--  Tab content  -->
        <Grid Grid.Row="3">
            <!--  ===== Logs (default, full height) =====  -->
            <Grid x:Name="LogsPanel" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="6">
                        <TextBox
                            x:Name="SearchBox"
                            Width="240"
                            MinWidth="120"
                            PlaceholderText="Search logs…"
                            TextChanged="SearchBox_TextChanged"
                            ToolTipService.ToolTip="Filter and highlight matching lines" />
                        <TextBlock
                            x:Name="MatchCountText"
                            MinWidth="64"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}" />
                        <Button
                            x:Name="PrevMatchButton"
                            Padding="7,5"
                            Click="PrevMatch_Click"
                            IsEnabled="False"
                            ToolTipService.ToolTip="Previous match">
                            <FontIcon FontSize="12" Glyph="&#xE70E;" />
                        </Button>
                        <Button
                            x:Name="NextMatchButton"
                            Padding="7,5"
                            Click="NextMatch_Click"
                            IsEnabled="False"
                            ToolTipService.ToolTip="Next match">
                            <FontIcon FontSize="12" Glyph="&#xE70D;" />
                        </Button>
                        <ToggleButton
                            x:Name="CaseToggle"
                            Padding="9,5"
                            Click="SearchOption_Click"
                            Content="Aa"
                            ToolTipService.ToolTip="Match case" />
                        <ToggleButton
                            x:Name="FilterToggle"
                            Padding="8,5"
                            Click="SearchOption_Click"
                            ToolTipService.ToolTip="Show only lines that match the search">
                            <FontIcon FontSize="14" Glyph="&#xE71C;" />
                        </ToggleButton>
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                        <ToggleButton
                            x:Name="HighlightErrorsToggle"
                            Padding="8,5"
                            Click="HighlightErrors_Click"
                            ToolTipService.ToolTip="Highlight error and warning lines">
                            <FontIcon FontSize="14" Glyph="&#xE7BA;" />
                        </ToggleButton>
                        <ToggleButton
                            x:Name="WrapToggle"
                            Padding="8,5"
                            Click="WrapToggle_Click"
                            ToolTipService.ToolTip="Wrap long lines">
                            <FontIcon FontSize="14" Glyph="&#xE751;" />
                        </ToggleButton>
                        <AppBarSeparator Margin="0" Padding="0" />
                        <Button
                            Click="ExportLogs_Click"
                            ToolTipService.ToolTip="Save the visible log to a text file">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="13" Glyph="&#xE74E;" />
                                <TextBlock Text="Export" />
                            </StackPanel>
                        </Button>
                        <Button
                            Click="ClearLogs_Click"
                            ToolTipService.ToolTip="Clear the log view">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon FontSize="13" Glyph="&#xE74D;" />
                                <TextBlock Text="Clear" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border
                    Grid.Row="1"
                    Background="#0C0C0F"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <ScrollViewer
                        x:Name="LogScroll"
                        Padding="14,10"
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Auto"
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            x:Name="LogText"
                            FontFamily="Cascadia Mono, Consolas"
                            FontSize="13"
                            Foreground="#E4E4E8"
                            IsTextSelectionEnabled="True"
                            LineHeight="19"
                            TextWrapping="NoWrap" />
                    </ScrollViewer>
                </Border>
            </Grid>

            <!--  ===== Summary =====  -->
            <ScrollViewer x:Name="SummaryPanel" Visibility="Collapsed">
                <StackPanel MaxWidth="900" Spacing="12">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <Grid ColumnSpacing="24" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Container ID" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                FontFamily="Consolas"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.Selected.ShortId, Mode=OneWay}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="State" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{x:Bind ViewModel.Selected.State, Mode=OneWay, Converter={StaticResource StateToString}}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Image" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.Selected.Image, Mode=OneWay}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Ports" />
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="1"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.Selected.PortsDisplay, Mode=OneWay}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="IP address" />
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="1"
                                FontFamily="Consolas"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.DetailIp, Mode=OneWay}" />

                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Network" />
                            <TextBlock
                                Grid.Row="5"
                                Grid.Column="1"
                                Text="{x:Bind ViewModel.DetailNetwork, Mode=OneWay}" />

                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Started" />
                            <TextBlock
                                Grid.Row="6"
                                Grid.Column="1"
                                Text="{x:Bind ViewModel.DetailStarted, Mode=OneWay}" />

                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Command" />
                            <TextBlock
                                Grid.Row="7"
                                Grid.Column="1"
                                FontFamily="Consolas"
                                FontSize="12"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.DetailCommand, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </Border>

                    <Expander
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Header="Environment variables">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DetailEnvironment, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock
                                        Margin="0,2"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        IsTextSelectionEnabled="True"
                                        Text="{x:Bind}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                    <Expander
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Header="Mounts">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DetailMounts, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock
                                        Margin="0,2"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        IsTextSelectionEnabled="True"
                                        Text="{x:Bind}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <!--  ===== Stats =====  -->
            <ScrollViewer x:Name="StatsPanel" Visibility="Collapsed">
                <StackPanel MaxWidth="900" Spacing="14">
                    <!--  CPU + Memory big meters  -->
                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        FontSize="16"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Glyph="&#xE950;" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CPU" />
                                </StackPanel>
                                <TextBlock FontSize="30" FontWeight="SemiBold" Text="{x:Bind ViewModel.StatCpu, Mode=OneWay}" />
                                <ProgressBar Maximum="100" Value="{x:Bind ViewModel.StatCpuValue, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon
                                        FontSize="16"
                                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                        Glyph="&#xEEA0;" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Memory" />
                                </StackPanel>
                                <TextBlock FontSize="30" FontWeight="SemiBold" Text="{x:Bind ViewModel.StatMem, Mode=OneWay}" />
                                <ProgressBar Maximum="100" Value="{x:Bind ViewModel.StatMemValue, Mode=OneWay}" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.StatMemUsage, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  I/O + PIDs  -->
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="24" RowSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Network I/O" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                FontFamily="Consolas"
                                Text="{x:Bind ViewModel.StatNetIO, Mode=OneWay}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Block I/O" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                FontFamily="Consolas"
                                Text="{x:Bind ViewModel.StatBlockIO, Mode=OneWay}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Processes (PIDs)" />
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="1"
                                FontFamily="Consolas"
                                Text="{x:Bind ViewModel.StatPids, Mode=OneWay}" />
                        </Grid>
                    </Border>

                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="Updates every 2 seconds. Stats are only available while the container is running." />
                </StackPanel>
            </ScrollViewer>

            <!--  ===== Files =====  -->
            <Grid
                x:Name="FilesPanel"
                RowSpacing="8"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Navigation toolbar  -->
                <Grid
                    Grid.Row="0"
                    ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Height="32"
                        Padding="10,0"
                        Click="FilesUp_Click"
                        IsEnabled="{x:Bind ViewModel.CanNavigateUp, Mode=OneWay}"
                        ToolTipService.ToolTip="Navigate up">
                        <FontIcon FontSize="13" Glyph="&#xE74A;" />
                    </Button>
                    <Button
                        Grid.Column="1"
                        Height="32"
                        Padding="10,0"
                        Click="FilesRefresh_Click"
                        ToolTipService.ToolTip="Refresh">
                        <FontIcon FontSize="13" Glyph="&#xE72C;" />
                    </Button>
                    <Border
                        Grid.Column="2"
                        Height="32"
                        Padding="10,0"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="12"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind ViewModel.FilesCurrentPath, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Center" />
                    </Border>
                    <Button
                        Grid.Column="3"
                        Height="32"
                        Padding="10,0"
                        Click="FilesNewFolder_Click"
                        ToolTipService.ToolTip="New folder">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon FontSize="13" Glyph="&#xE8F4;" />
                            <TextBlock
                                FontSize="12"
                                Text="New folder"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="4"
                        Height="32"
                        Padding="10,0"
                        Click="CopyInFile_Click"
                        ToolTipService.ToolTip="Upload files from host to current directory">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon FontSize="13" Glyph="&#xE898;" />
                            <TextBlock
                                FontSize="12"
                                Text="Upload"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="5"
                        Height="32"
                        Padding="10,0"
                        Click="CopyInFolder_Click"
                        ToolTipService.ToolTip="Upload folder from host to current directory">
                        <FontIcon FontSize="13" Glyph="&#xE8DA;" />
                    </Button>
                </Grid>

                <!--  File list area with drag-drop  -->
                <Border
                    x:Name="DropZoneBorder"
                    Grid.Row="1"
                    AllowDrop="True"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    DragEnter="DropZone_DragEnter"
                    DragLeave="DropZone_DragLeave"
                    DragOver="DropZone_DragOver"
                    Drop="DropZone_Drop">
                    <Grid>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  Column headers  -->
                            <Grid
                                Grid.Row="0"
                                Padding="16,8"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="128" />
                                    <ColumnDefinition Width="100" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="Name" />
                                <TextBlock
                                    Grid.Column="2"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="Type" />
                                <TextBlock
                                    Grid.Column="3"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="Size" />
                                <TextBlock
                                    Grid.Column="4"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="Modified" />
                                <TextBlock
                                    Grid.Column="5"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Text="Permissions" />
                            </Grid>

                            <!--  File list  -->
                            <ListView
                                x:Name="FilesList"
                                Grid.Row="1"
                                CanDragItems="True"
                                DragItemsStarting="FilesList_DragItemsStarting"
                                DoubleTapped="FilesList_DoubleTapped"
                                ItemsSource="{x:Bind ViewModel.DetailFiles, Mode=OneWay}"
                                RightTapped="FilesList_RightTapped"
                                SelectedItem="{x:Bind ViewModel.SelectedFile, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ContainerFileEntry">
                                        <Grid
                                            Padding="16,6"
                                            ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="128" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon
                                                Grid.Column="0"
                                                FontSize="15"
                                                Glyph="{x:Bind IconGlyph}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{x:Bind Name}"
                                                TextTrimming="CharacterEllipsis"
                                                ToolTipService.ToolTip="{x:Bind Name}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Grid.Column="2"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind TypeDisplay}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Grid.Column="3"
                                                FontSize="12"
                                                Text="{x:Bind SizeDisplay}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Grid.Column="4"
                                                FontSize="12"
                                                Text="{x:Bind ModifiedDisplay}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Grid.Column="5"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Text="{x:Bind Permissions}"
                                                VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>

                        <!--  Drop overlay (shown when files are dragged over the panel)  -->
                        <Border
                            x:Name="DropOverlay"
                            Background="#220078D4"
                            BorderBrush="#780078D4"
                            BorderThickness="2"
                            CornerRadius="8"
                            IsHitTestVisible="False"
                            Visibility="Collapsed">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <FontIcon
                                    FontSize="40"
                                    Foreground="#0078D4"
                                    Glyph="&#xE898;" />
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="#0078D4"
                                    HorizontalAlignment="Center"
                                    Text="Drop to upload" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    HorizontalAlignment="Center"
                                    Text="Files and folders will be copied into the current directory" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!--  Status bar  -->
                <TextBlock
                    Grid.Row="2"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.FilesStatusMessage, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>

            <!--  ===== Inspect =====  -->
            <Border
                x:Name="InspectPanel"
                Background="#0C0C0F"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="Collapsed">
                <ScrollViewer
                    Padding="14,10"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <TextBlock
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="12"
                        Foreground="#E4E4E8"
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind ViewModel.DetailInspectJson, Mode=OneWay}"
                        TextWrapping="NoWrap" />
                </ScrollViewer>
            </Border>

            <!--  ===== Changes (docker diff equivalent) =====  -->
            <Grid
                x:Name="ChangesPanel"
                RowSpacing="8"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Toolbar  -->
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        Height="32"
                        Padding="10,0"
                        Click="ChangesRefresh_Click"
                        ToolTipService.ToolTip="Recompute changes">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon FontSize="13" Glyph="&#xE72C;" />
                            <TextBlock
                                FontSize="12"
                                Text="Refresh"
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock
                        Grid.Column="1"
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Files added (A), changed (C), or deleted (D) versus the image."
                        TextTrimming="CharacterEllipsis"
                        VerticalAlignment="Center" />
                    <ProgressRing
                        Grid.Column="2"
                        Width="18"
                        Height="18"
                        IsActive="{x:Bind ViewModel.IsChangesBusy, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsChangesBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                </Grid>

                <!--  Change list  -->
                <Border
                    Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <ListView
                            x:Name="ChangesList"
                            Padding="4"
                            IsItemClickEnabled="False"
                            ItemsSource="{x:Bind ViewModel.DetailChanges, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ContainerFsChange">
                                    <Grid ColumnSpacing="10" Padding="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Width="22"
                                            Height="22"
                                            Background="{x:Bind KindColorHex, Converter={StaticResource HexToBrush}}"
                                            CornerRadius="4"
                                            ToolTipService.ToolTip="{x:Bind KindLabel}"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Foreground="White"
                                                HorizontalAlignment="Center"
                                                Text="{x:Bind KindGlyph}"
                                                VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock
                                            Grid.Column="1"
                                            FontFamily="Cascadia Mono, Consolas"
                                            FontSize="12"
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind Path}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!--  Status bar  -->
                <TextBlock
                    Grid.Row="2"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{x:Bind ViewModel.ChangesStatusMessage, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </Grid>
        </Grid>
    </Grid>
</Page>
