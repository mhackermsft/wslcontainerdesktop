<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WslContainerDesktop.Views.KubernetesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WslContainerDesktop.Helpers"
    xmlns:controls="using:WslContainerDesktop.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:k8s="using:WslContainerDesktop.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:EmptyToVisibilityConverter x:Key="EmptyToVis" />
        <converters:StringEqualsToVisibilityConverter x:Key="SectionVis" />
        <converters:StringEqualsToVisibilityConverter x:Key="SectionVisInverse" IsInverse="True" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18,16" />
        </Style>
        <Style x:Key="ListCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style x:Key="ColHead" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextBlockStyle}">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="K8sRowStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="16,4,12,4" />
            <Setter Property="MinHeight" Value="48" />
        </Style>
    </Page.Resources>

    <Grid Margin="24,16,24,16" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Kubernetes" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </StackPanel>

        <!--  Status / control card  -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Width="52"
                    Height="52"
                    VerticalAlignment="Center"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <FontIcon
                        FontSize="24"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Glyph="&#xEB3C;" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="k3s single-node cluster" />
                        <Border
                            Padding="10,2"
                            VerticalAlignment="Center"
                            Background="#1F7A3D"
                            CornerRadius="10"
                            Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12" Foreground="White" Text="Running" />
                        </Border>
                        <Border
                            Padding="10,2"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind ViewModel.IsStopped, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Stopped" />
                        </Border>
                        <Border
                            Padding="10,2"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="10"
                            Visibility="{x:Bind ViewModel.IsNotInstalled, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Not installed" />
                        </Border>
                    </StackPanel>
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="16"
                        Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            <Run Text="Node:" />
                            <Run Text="{x:Bind ViewModel.NodeName, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            <Run Text="Version:" />
                            <Run Text="{x:Bind ViewModel.KubernetesVersion, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                            <Run Text="Distro:" />
                            <Run Text="{x:Bind ViewModel.Distro, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <ProgressRing
                        Width="24"
                        Height="24"
                        IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    <Button
                        Command="{x:Bind ViewModel.InstallCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        Visibility="{x:Bind ViewModel.IsNotInstalled, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE896;" />
                            <TextBlock Text="Install Kubernetes" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.StartCommand}"
                        Style="{ThemeResource AccentButtonStyle}"
                        Visibility="{x:Bind ViewModel.IsStopped, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE768;" />
                            <TextBlock Text="Start" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.StopCommand}"
                        Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE71A;" />
                            <TextBlock Text="Stop" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.UpgradeCommand}"
                        Visibility="{x:Bind ViewModel.IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE896;" />
                            <TextBlock Text="Upgrade" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.UninstallCommand}"
                        Visibility="{x:Bind ViewModel.IsInstalled, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                            <TextBlock Text="Uninstall" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--  Body  -->
        <Grid Grid.Row="2">

            <!--  Not-installed hero  -->
            <StackPanel
                MaxWidth="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="14"
                Visibility="{x:Bind ViewModel.IsNotInstalled, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="52"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Glyph="&#xEB3C;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="No Kubernetes cluster yet" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Install a lightweight single-node Kubernetes cluster (k3s) that runs inside your WSL distro. It uses its own container runtime, installs as a service, and can be fully uninstalled at any time."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <Button
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.InstallCommand}"
                    Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE896;" />
                        <TextBlock Text="Install Kubernetes (k3s)" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!--  Operation log  -->
            <Border
                Background="#0C0C0F"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{x:Bind ViewModel.ShowOperationLog, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <ScrollViewer x:Name="LogScroll" Padding="14,10" VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            x:Name="LogText"
                            FontFamily="Cascadia Mono, Consolas"
                            FontSize="12"
                            Foreground="#E4E4E8"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind ViewModel.OperationLog, Mode=OneWay}"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                    <Button
                        Margin="0,8,12,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Click="HideLog_Click"
                        Content="Hide log"
                        Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                </Grid>
            </Border>

            <!--  Stopped hint  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="10"
                Visibility="{x:Bind ViewModel.IsStopped, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="44"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Glyph="&#xE769;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Cluster is stopped. Click Start to bring it up." />
            </StackPanel>

            <!--  ===== Running: sub-nav shell =====  -->
            <Grid ColumnSpacing="14" Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Sub-nav  -->
                <Border Grid.Column="0" Style="{StaticResource ListCard}">
                    <ListView
                        Padding="4,6"
                        SelectedItem="{x:Bind ViewModel.SelectedSection, Mode=TwoWay}"
                        SelectionMode="Single">
                        <x:String>Dashboard</x:String>
                        <x:String>Nodes</x:String>
                        <x:String>Deployments</x:String>
                        <x:String>Pods</x:String>
                        <x:String>Services</x:String>
                        <x:String>Ingresses</x:String>
                        <x:String>Persistent Volume Claims</x:String>
                        <x:String>ConfigMaps</x:String>
                        <x:String>Secrets</x:String>
                        <x:String>Jobs</x:String>
                        <x:String>CronJobs</x:String>
                        <x:String>Port Forwarding</x:String>
                    </ListView>
                </Border>

                <!--  Content  -->
                <Grid Grid.Column="1" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Namespace bar  -->
                    <Grid Grid.Row="0">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.SelectedSection, Mode=OneWay}" />
                        <StackPanel
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="12">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="8"
                                Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVisInverse}, ConverterParameter=Port Forwarding}">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Namespace:" />
                                <ComboBox
                                    MinWidth="180"
                                    ItemsSource="{x:Bind ViewModel.Namespaces, Mode=OneWay}"
                                    SelectedItem="{x:Bind ViewModel.SelectedNamespace, Mode=TwoWay}" />
                            </StackPanel>
                            <Button
                                VerticalAlignment="Center"
                                Command="{x:Bind ViewModel.ApplyYamlCommand}"
                                Style="{ThemeResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Deploy a Kubernetes YAML manifest">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE898;" />
                                    <TextBlock Text="Apply YAML" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!--  Section panels  -->
                    <Grid Grid.Row="1">

                        <!--  Dashboard  -->
                        <controls:K8sDashboardSection
                            ViewModel="{x:Bind ViewModel}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Dashboard}" />

                        <!--  Nodes  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Nodes}">
                            <ListView
                                IsItemClickEnabled="True"
                                ItemClick="Resource_ItemClick"
                                ItemContainerStyle="{StaticResource K8sRowStyle}"
                                ItemsSource="{x:Bind ViewModel.Nodes, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="k8s:K8sNode">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="140" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" MinWidth="120" />
                                                <ColumnDefinition Width="16" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind Status}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Roles}" />
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Version}" />
                                            <FontIcon Grid.Column="4" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Glyph="&#xE76C;" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!--  Deployments  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Deployments}">
                            <ListView
                                IsItemClickEnabled="True"
                                ItemClick="Resource_ItemClick"
                                ItemContainerStyle="{StaticResource K8sRowStyle}"
                                ItemsSource="{x:Bind ViewModel.Deployments, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="k8s:K8sDeployment">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="160" />
                                                <ColumnDefinition Width="1.2*" MinWidth="110" />
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Ready}" />
                                            <StackPanel Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="2">
                                                <Button Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Scale" Click="ScaleDeployment_Click" ToolTipService.ToolTip="Scale">
                                                    <FontIcon FontSize="14" Glyph="&#xE740;" />
                                                </Button>
                                                <Button Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Rolling restart" Click="RestartDeployment_Click" ToolTipService.ToolTip="Rolling restart">
                                                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                                </Button>
                                                <Button Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!--  Pods  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Pods}">
                            <ListView
                                IsItemClickEnabled="True"
                                ItemClick="Resource_ItemClick"
                                ItemContainerStyle="{StaticResource K8sRowStyle}"
                                ItemsSource="{x:Bind ViewModel.Pods, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="k8s:K8sPod">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="160" />
                                                <ColumnDefinition Width="1.2*" MinWidth="100" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Status}" />
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind Ready}" />
                                            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{x:Bind Restarts}" />
                                            <StackPanel Grid.Column="5" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="2">
                                                <Button Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!--  Services  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Services}">
                            <ListView
                                IsItemClickEnabled="True"
                                ItemClick="Resource_ItemClick"
                                ItemContainerStyle="{StaticResource K8sRowStyle}"
                                ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="k8s:K8sService">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="150" />
                                                <ColumnDefinition Width="1.2*" MinWidth="100" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" MinWidth="90" />
                                                <ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Type}" />
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Text="{x:Bind ClusterIP}" />
                                            <TextBlock Grid.Column="4" VerticalAlignment="Center" FontSize="12" Text="{x:Bind Ports}" />
                                            <Button Grid.Column="5" Width="34" Height="34" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!--  Ingresses  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Ingresses}">
                            <Grid>
                                <TextBlock
                                    Margin="16,14"
                                    VerticalAlignment="Top"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="No ingresses."
                                    Visibility="{x:Bind ViewModel.Ingresses.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}" />
                                <ListView
                                    IsItemClickEnabled="True"
                                    ItemClick="Resource_ItemClick"
                                    ItemContainerStyle="{StaticResource K8sRowStyle}"
                                    ItemsSource="{x:Bind ViewModel.Ingresses, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="k8s:K8sIngress">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" MinWidth="150" />
                                                    <ColumnDefinition Width="1.2*" MinWidth="100" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="*" MinWidth="120" />
                                                    <ColumnDefinition Width="44" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Class}" />
                                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind Hosts}" TextTrimming="CharacterEllipsis" />
                                                <Button Grid.Column="4" Width="34" Height="34" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <!--  PVCs  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Persistent Volume Claims}">
                            <Grid>
                                <TextBlock
                                    Margin="16,14"
                                    VerticalAlignment="Top"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="No persistent volume claims."
                                    Visibility="{x:Bind ViewModel.Pvcs.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}" />
                                <ListView
                                    IsItemClickEnabled="True"
                                    ItemClick="Resource_ItemClick"
                                    ItemContainerStyle="{StaticResource K8sRowStyle}"
                                    ItemsSource="{x:Bind ViewModel.Pvcs, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="k8s:K8sPvc">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" MinWidth="150" />
                                                    <ColumnDefinition Width="1.2*" MinWidth="100" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="*" MinWidth="110" />
                                                    <ColumnDefinition Width="44" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Status}" />
                                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind Capacity}" />
                                                <TextBlock Grid.Column="4" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind StorageClass}" TextTrimming="CharacterEllipsis" />
                                                <Button Grid.Column="5" Width="34" Height="34" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <!--  ConfigMaps  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=ConfigMaps}">
                            <ListView
                                IsItemClickEnabled="True"
                                ItemClick="Resource_ItemClick"
                                ItemContainerStyle="{StaticResource K8sRowStyle}"
                                ItemsSource="{x:Bind ViewModel.ConfigMaps, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="k8s:K8sConfigMap">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="160" />
                                                <ColumnDefinition Width="1.2*" MinWidth="110" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Keys}" />
                                            <Button Grid.Column="3" Width="34" Height="34" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!--  Secrets  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Secrets}">
                            <ListView
                                IsItemClickEnabled="True"
                                ItemClick="Resource_ItemClick"
                                ItemContainerStyle="{StaticResource K8sRowStyle}"
                                ItemsSource="{x:Bind ViewModel.Secrets, Mode=OneWay}"
                                SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="k8s:K8sSecret">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="160" />
                                                <ColumnDefinition Width="1.2*" MinWidth="110" />
                                                <ColumnDefinition Width="1.4*" MinWidth="150" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Type}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind Keys}" />
                                            <Button Grid.Column="4" Width="34" Height="34" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <!--  Jobs  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Jobs}">
                            <Grid>
                                <TextBlock
                                    Margin="16,14"
                                    VerticalAlignment="Top"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="No jobs."
                                    Visibility="{x:Bind ViewModel.Jobs.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}" />
                                <ListView
                                    IsItemClickEnabled="True"
                                    ItemClick="Resource_ItemClick"
                                    ItemContainerStyle="{StaticResource K8sRowStyle}"
                                    ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="k8s:K8sJob">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" MinWidth="160" />
                                                    <ColumnDefinition Width="1.2*" MinWidth="110" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="44" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Completions}" />
                                                <Button Grid.Column="3" Width="34" Height="34" Padding="0" HorizontalAlignment="Right" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <!--  CronJobs  -->
                        <Border
                            Style="{StaticResource ListCard}"
                            Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=CronJobs}">
                            <Grid>
                                <TextBlock
                                    Margin="16,14"
                                    VerticalAlignment="Top"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="No cronjobs."
                                    Visibility="{x:Bind ViewModel.CronJobs.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}" />
                                <ListView
                                    IsItemClickEnabled="True"
                                    ItemClick="Resource_ItemClick"
                                    ItemContainerStyle="{StaticResource K8sRowStyle}"
                                    ItemsSource="{x:Bind ViewModel.CronJobs, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="k8s:K8sCronJob">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" MinWidth="150" />
                                                    <ColumnDefinition Width="1.2*" MinWidth="100" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="118" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontWeight="SemiBold" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Namespace}" />
                                                <TextBlock Grid.Column="2" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12" Text="{x:Bind Schedule}" />
                                                <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind Active}" />
                                                <StackPanel Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Spacing="2">
                                                    <Button Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Run now" Click="RunCron_Click" ToolTipService.ToolTip="Run now">
                                                        <FontIcon FontSize="14" Glyph="&#xE768;" />
                                                    </Button>
                                                    <Button Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Suspend / resume" Click="ToggleCron_Click" ToolTipService.ToolTip="Suspend / resume">
                                                        <FontIcon FontSize="14" Glyph="&#xE769;" />
                                                    </Button>
                                                    <Button Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Delete" Click="DeleteResource_Click" ToolTipService.ToolTip="Delete">
                                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <!--  Port Forwarding  -->
                        <Grid Visibility="{x:Bind ViewModel.SelectedSection, Mode=OneWay, Converter={StaticResource SectionVis}, ConverterParameter=Port Forwarding}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Button
                                Grid.Row="0"
                                Margin="0,0,0,10"
                                Command="{x:Bind ViewModel.AddPortForwardCommand}"
                                Style="{ThemeResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontSize="14" Glyph="&#xE71B;" />
                                    <TextBlock Text="Forward a port" />
                                </StackPanel>
                            </Button>

                            <Border Grid.Row="1" Style="{StaticResource ListCard}">
                                <Grid>
                                    <StackPanel
                                        Margin="0,60,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Top"
                                        Spacing="10"
                                        Visibility="{x:Bind ViewModel.PortForwards.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            FontSize="36"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Glyph="&#xE71B;" />
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="No active port forwards. Click &quot;Forward a port&quot; to expose a pod or service on localhost." />
                                    </StackPanel>

                                    <ScrollViewer>
                                        <ItemsControl ItemsSource="{x:Bind ViewModel.PortForwards, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="k8s:PortForward">
                                                    <Grid Padding="16,10" ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140" />
                                                            <ColumnDefinition Width="*" MinWidth="180" />
                                                            <ColumnDefinition Width="1.2*" MinWidth="110" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal" Spacing="8">
                                                            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Fill="#2DC85F" />
                                                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold">
                                                                <Run Text="localhost:" />
                                                                <Run Text="{x:Bind LocalPort}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            FontFamily="Consolas"
                                                            FontSize="12"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{x:Bind TargetRef}"
                                                            TextTrimming="CharacterEllipsis" />
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Text="{x:Bind Namespace}" />
                                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                                            <Button
                                                                Padding="7,5"
                                                                Click="OpenForward_Click"
                                                                ToolTipService.ToolTip="Open in browser">
                                                                <FontIcon FontSize="14" Glyph="&#xE774;" />
                                                            </Button>
                                                            <Button
                                                                Padding="7,5"
                                                                Click="StopForward_Click"
                                                                ToolTipService.ToolTip="Stop">
                                                                <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
