<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WslContainerDesktop.Views.ReclaimSpacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WslContainerDesktop.Helpers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WslContainerDesktop.Models"
    x:Name="Root"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:EmptyToVisibilityConverter x:Key="EmptyToVis" />
        <converters:BytesToSizeConverter x:Key="BytesToSize" />
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="18,16" />
        </Style>
        <Style x:Key="ListCard" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="16,10" />
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer>
            <StackPanel Margin="24,16,24,24" Spacing="16">

                <!--  Header  -->
                <StackPanel Spacing="2">
                    <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Reclaim space" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                </StackPanel>

                <!--  Actions  -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Command="{x:Bind ViewModel.PruneAllCommand}" Style="{ThemeResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                            <TextBlock Text="Reclaim all" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Reclaimable summary banner  -->
                <Border Style="{StaticResource StatCard}">
                    <StackPanel Spacing="4">
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Reclaimable (dangling images)" />
                        <TextBlock
                            FontSize="30"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.TotalReclaimableSize, Mode=OneWay}" />
                        <TextBlock
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                            Text="wslc does not report container or volume sizes, so those are shown as counts." />
                    </StackPanel>
                </Border>

                <!--  Per-resource cards  -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Images  -->
                    <Border Grid.Column="0" Style="{StaticResource StatCard}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xEB9F;" />
                                <TextBlock FontWeight="SemiBold" Text="Images" />
                            </StackPanel>
                            <TextBlock>
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Total:" />
                                <Run Text="{x:Bind ViewModel.ImagesTotalSize, Mode=OneWay}" />
                                <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="  ·" />
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.ImageCount, Mode=OneWay}" />
                                <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="images" />
                            </TextBlock>
                            <TextBlock>
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Reclaimable:" />
                                <Run Text="{x:Bind ViewModel.ImagesReclaimableSize, Mode=OneWay}" />
                                <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="  ·" />
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.DanglingImageCount, Mode=OneWay}" />
                                <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="dangling" />
                            </TextBlock>
                            <Button
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.PruneImagesCommand}"
                                Content="Remove dangling images" />
                        </StackPanel>
                    </Border>

                    <!--  Containers  -->
                    <Border Grid.Column="1" Style="{StaticResource StatCard}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE7F4;" />
                                <TextBlock FontWeight="SemiBold" Text="Containers" />
                            </StackPanel>
                            <TextBlock>
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Total:" />
                                <Run Text="{x:Bind ViewModel.ContainerCount, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock>
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Stopped:" />
                                <Run Text="{x:Bind ViewModel.StoppedContainerCount, Mode=OneWay}" />
                                <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="reclaimable" />
                            </TextBlock>
                            <Button
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.PruneContainersCommand}"
                                Content="Remove stopped containers" />
                        </StackPanel>
                    </Border>

                    <!--  Volumes  -->
                    <Border Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon
                                    FontSize="16"
                                    Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                    Glyph="&#xE8B7;" />
                                <TextBlock FontWeight="SemiBold" Text="Volumes" />
                            </StackPanel>
                            <TextBlock>
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Total:" />
                                <Run Text="{x:Bind ViewModel.VolumeCount, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock>
                                <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Unused:" />
                                <Run Text="{x:Bind ViewModel.UnusedVolumeCount, Mode=OneWay}" />
                                <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="anonymous" />
                            </TextBlock>
                            <Button
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.PruneVolumesCommand}"
                                Content="Remove unused volumes" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!--  Largest images  -->
                <TextBlock
                    Margin="2,4,0,0"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Largest images" />
                <Border Style="{StaticResource ListCard}">
                    <StackPanel Spacing="2">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.LargestImages, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ImageInfo">
                                    <Grid Padding="0,6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="160" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontFamily="Consolas"
                                            FontSize="13"
                                            Text="{x:Bind Reference}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontFamily="Consolas"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind ShortId}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            Text="{x:Bind Size, Converter={StaticResource BytesToSize}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock
                            Margin="0,8"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="No images."
                            Visibility="{x:Bind ViewModel.LargestImages.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}" />
                    </StackPanel>
                </Border>

                <!--  Dangling images  -->
                <TextBlock
                    Margin="2,4,0,0"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Dangling images" />
                <Border Style="{StaticResource ListCard}">
                    <StackPanel Spacing="2">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.DanglingImages, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ImageInfo">
                                    <Grid Padding="0,6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="160" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontFamily="Consolas"
                                            FontSize="13"
                                            Text="{x:Bind ShortId}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="13"
                                            Text="{x:Bind Size, Converter={StaticResource BytesToSize}}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock
                            Margin="0,8"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="No dangling images."
                            Visibility="{x:Bind ViewModel.DanglingImages.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}" />
                    </StackPanel>
                </Border>

                <!--  Unused volumes  -->
                <TextBlock
                    Margin="2,4,0,0"
                    Style="{ThemeResource BodyStrongTextBlockStyle}"
                    Text="Unused volumes" />
                <Border Style="{StaticResource ListCard}">
                    <StackPanel Spacing="2">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.UnusedVolumes, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:VolumeInfo">
                                    <Grid Padding="0,6" ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="160" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontFamily="Consolas"
                                            FontSize="13"
                                            Text="{x:Bind DisplayName}"
                                            ToolTipService.ToolTip="{x:Bind Name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            Text="{x:Bind TypeLabel}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock
                            Margin="0,8"
                            HorizontalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="No unused volumes."
                            Visibility="{x:Bind ViewModel.UnusedVolumes.Count, Mode=OneWay, Converter={StaticResource EmptyToVis}}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ProgressBar
            VerticalAlignment="Top"
            IsIndeterminate="True"
            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
    </Grid>
</Page>
